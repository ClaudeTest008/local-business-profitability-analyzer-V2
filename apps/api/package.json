    "@lboa/providers": "workspace:*",
    "@lboa/rules": "workspace:*",
    "@lboa/shared": "workspace:*",
    "@lboa/taxonomy": "workspace:*",
    "@lboa/types": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.2",
    "tsx": "^4.19.2"
  }
