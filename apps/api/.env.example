# @lboa/api environment — all variables are optional; defaults shown.

# HTTP listener
PORT=3001
HOST=0.0.0.0

# PostgreSQL connection string. Unset = in-memory repository (data lost on restart).
# DATABASE_URL=postgres://user:pass@localhost:5432/lboa

# Redis connection string for the provider cache. Unset = in-memory cache.
# REDIS_URL=redis://localhost:6379

# 'fixture' = deterministic offline POI provider (demo/tests).
# 'live'    = Overpass API primary with fixture fallback (ADR-002).
DATA_MODE=fixture

# CORS allowed origin. '*' allows any origin.
CORS_ORIGIN=*
